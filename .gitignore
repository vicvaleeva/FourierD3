# Allowlist: the repo only tracks src/, data/, README.md, pyproject.toml
# Ignore everything at the top level...
/*
# ...except these
!/src/
!/data/
!/README.md
!/pyproject.toml
!/.gitignore

# Always ignore caches / build / OS junk, even inside kept dirs
__pycache__/
*.py[cod]
*.egg-info/
build/
.DS_Store
